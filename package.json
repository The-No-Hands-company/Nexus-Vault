{
  "name": "nexus-vault",
  "version": "0.1.0",
  "type": "module",
  "description": "Self-hosted, encrypted API key management with audit logs — part of the Nexus ecosystem",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "setup": "tsx src/setup.ts",
    "test": "npx vitest run --testTimeout=15000 src/routes/*.test.ts",
    "typecheck": "tsc --noEmit",
    "migrate": "tsx src/migrate.ts",
    "backup": "tsx src/backup.ts",
    "rotate-secret": "tsx src/rotate-master-secret.ts",
    "audit:verify": "tsx src/audit-verify.ts",
    "security:audit": "npm audit --omit=dev --audit-level=high",
    "release:check": "npm run typecheck && npm test && npm run build && npm pack --dry-run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1034.0",
    "better-sqlite3": "^9.6.0",
    "cors": "^2.8.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "nodemailer": "^8.0.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.20",
    "@types/nodemailer": "^8.0.0",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^4.1.4"
  }
}
