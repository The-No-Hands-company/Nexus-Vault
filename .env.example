# ── DevVault environment ──────────────────────────────────────────────────────
# Copy this to .env and fill in real values. NEVER commit .env.

# Master encryption secret — used to derive the AES-256 key for stored values.
# Generate: openssl rand -base64 48
VAULT_MASTER_SECRET=change-me-to-a-long-random-string-32-chars-min

# Read-only bearer token — for projects pulling keys at runtime.
# Generate: openssl rand -hex 32
VAULT_ACCESS_TOKEN=change-me-read-only-token

# Admin bearer token — for dashboard, creating/editing/deleting keys.
# Generate: openssl rand -hex 32
VAULT_ADMIN_TOKEN=change-me-admin-token-keep-this-secret

# Optional token hardening (defaults shown)
# Support rotation by comma-separating old/new tokens in VAULT_ACCESS_TOKEN/VAULT_ADMIN_TOKEN.
VAULT_MIN_TOKEN_LENGTH=24
# VAULT_ALLOW_WEAK_TOKENS=true

# Server port (default: 3900)
PORT=3900

# Where to store vault.db (default: ./data)
VAULT_DATA_DIR=./data

# Backup destination used by `npm run backup` (default: ./backups)
VAULT_BACKUP_DIR=./backups

# Keep only newest backup files in VAULT_BACKUP_DIR (default: 20)
VAULT_BACKUP_RETENTION_COUNT=20

# Maximum signed backup upload payload size in MB (default: 50)
VAULT_BACKUP_MAX_UPLOAD_MB=50

# Optional dedicated signing secret for backup upload/download tokens.
# Falls back to VAULT_ADMIN_TOKEN when unset.
# VAULT_BACKUP_SIGNING_SECRET=change-me-backup-signing-secret

# Verify tamper-evident audit chain at process startup (default: true)
VAULT_VERIFY_AUDIT_ON_START=true

# If startup verification fails, exit process (default: true)
# Set to false only for emergency read-only recovery scenarios.
VAULT_FAIL_ON_AUDIT_INTEGRITY_ERROR=true

# ── Periodic Verification & Alerting ──────────────────────────────────────────
# Enable background periodic audit integrity verification (default: true)
VAULT_PERIODIC_VERIFY_ENABLED=true

# How often to run periodic verification in hours (default: 24, min: 1)
VAULT_PERIODIC_VERIFY_INTERVAL_HOURS=24

# Webhook URL to send alerts when audit chain is broken (optional)
# VAULT_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Email address for audit failure alerts (optional, requires mail integration)
# VAULT_ALERT_EMAIL=ops@example.com

# SMTP settings for alert email delivery (required when VAULT_ALERT_EMAIL is set)
# VAULT_SMTP_HOST=smtp.example.com
# VAULT_SMTP_PORT=587
# VAULT_SMTP_SECURE=false
# VAULT_SMTP_USER=smtp-user
# VAULT_SMTP_PASS=smtp-password
# VAULT_SMTP_FROM=nexus-vault@example.com

# Throttle alerts to prevent spam — minutes between consecutive alerts (default: 60)
VAULT_ALERT_THROTTLE_MINUTES=60

# Optional SIEM webhook for structured audit exports (`/api/audit/export/siem`)
# VAULT_SIEM_WEBHOOK_URL=https://siem.example.com/ingest

# Restrict CORS to a specific origin (blank = deny all cross-origin requests)
# CORS_ORIGIN=http://localhost:5173
# CORS_ALLOW_CREDENTIALS=false
# CORS_ALLOW_WILDCARD=false

# Reverse proxy trust mode (for production behind ingress/LB):
# TRUST_PROXY=true
# TRUST_PROXY=1
# TRUST_PROXY=10.0.0.0/8,127.0.0.1

# CSP preset: compat (dashboard UI with inline assets) or strict (API-first lockdown)
# VAULT_CSP_PRESET=compat

# Allow framing when embedded (defaults to NEXUS_CLOUD_EMBEDDED)
# VAULT_ALLOW_EMBED=false

# Graceful shutdown drain timeout for HTTP server close (ms)
# VAULT_SHUTDOWN_TIMEOUT_MS=15000

# ── Nexus Cloud Embedding (optional) ──────────────────────────────────────────
# Configure cloud-discovery metadata for standalone vs embedded deployment.
# NEXUS_CLOUD_EMBEDDED=false
# NEXUS_CLOUD_REFERENCED=true
# NEXUS_CLOUD_BASE_URL=/api
# NEXUS_CLOUD_APP_ID=nexus-vault
# NEXUS_CLOUD_APP_NAME=Nexus Vault
# NEXUS_CLOUD_APP_ROLE=secrets-layer
# NEXUS_CLOUD_PROTOCOL=nexus-cloud/1.0
# NEXUS_CLOUD_HUB=Nexus Cloud
# NEXUS_CLOUD_REQUIRED_APIS=topology.v1,systems-api.v1
# NEXUS_CLOUD_CONSUMES=/api/keys,/api/audit
# NEXUS_CLOUD_EXPOSES=/.well-known/nexus-cloud,/api/cloud/discovery,/api/cloud/register,/api/cloud/client

# Optional HMAC auth for cloud registration handshake.
# Signature is HMAC-SHA256(secret, `${timestamp}.${JSON.stringify(body)}`)
# sent with X-Nexus-Timestamp and X-Nexus-Signature headers.
# NEXUS_CLOUD_REGISTER_SECRET=change-me-registration-shared-secret
# NEXUS_CLOUD_SIGNATURE_MAX_SKEW_SECONDS=300
# NEXUS_CLOUD_ALLOW_INSECURE_REGISTRATION_ENDPOINT=false
