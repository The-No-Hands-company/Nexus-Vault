# ── DevVault environment ──────────────────────────────────────────────────────
# Copy this to .env and fill in real values. NEVER commit .env.

# Master encryption secret — used to derive the AES-256 key for stored values.
# Generate: openssl rand -base64 48
VAULT_MASTER_SECRET=change-me-to-a-long-random-string-32-chars-min

# Read-only bearer token — for projects pulling keys at runtime.
# Generate: openssl rand -hex 32
VAULT_ACCESS_TOKEN=change-me-read-only-token

# Admin bearer token — for dashboard, creating/editing/deleting keys.
# Generate: openssl rand -hex 32
VAULT_ADMIN_TOKEN=change-me-admin-token-keep-this-secret

# Server port (default: 3900)
PORT=3900

# Where to store vault.db (default: ./data)
VAULT_DATA_DIR=./data

# Restrict CORS to a specific origin (blank = deny all cross-origin requests)
# CORS_ORIGIN=http://localhost:5173
